DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,SERVER_IP
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Keep these off while you are testing by IP or plain HTTP.
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

DB_NAME=cafe_skazka
DB_USER=cafe_user
DB_PASSWORD=replace-with-a-strong-db-password
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=1

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=0
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
TELEGRAM_POLLING_ENABLED=1

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_URL=https://api.yookassa.ru/v3

GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_LOG_LEVEL=info

DJANGO_RUN_MIGRATIONS=1
DJANGO_COLLECTSTATIC=1
